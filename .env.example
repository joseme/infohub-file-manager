# AnythingLLM API Configuration
ANYTHINGLLM_API_KEY=Tu clave de InfoHub
ANYTHINGLLM_BASE_URL=La URLde InfoHub

# Ollama Configuration (para descripciones de imágenes)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=modelo de Ollama

# Image Description Settings
IMAGE_DESCRIPTION_ACTIVATE=true

# Application Settings
APP_HOST=localhost
APP_PORT=8000
APP_TITLE=InfoHub File Manager

# Watched Folders Configuration
WATCHED_FOLDERS_ROOT= Carpeta de fuentes

# Logging
LOG_LEVEL=INFO
LOG_FILE=infohub.log
